# Copy to .dev.vars for local `astro dev` / `wrangler dev`.
# Production: set these in the Cloudflare dashboard (Worker → Settings → Variables).
# SITE_URL is build-time only — set it in Workers Builds → Build variables.
SITE_URL=http://localhost:4321
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
CONTACT_TO_EMAIL=hello@example.com
CONTACT_FROM_EMAIL=noreply@example.com
