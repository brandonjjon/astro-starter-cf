---
import { actions } from 'astro:actions';
import { PUBLIC_TURNSTILE_SITE_KEY } from 'astro:env/server';

const result = Astro.getActionResult(actions.submitContact);

// Cloudflare's official always-pass test site key. Used on *.workers.dev
// so preview/test deploys work without configuring a real Turnstile site.
// Real keys from the Turnstile dashboard are used on custom domains.
// https://developers.cloudflare.com/turnstile/troubleshooting/testing/
const TEST_SITE_KEY = '1x00000000000000000000AA';
const isWorkersDevHost = Astro.url.hostname.endsWith('.workers.dev');
const siteKey = isWorkersDevHost ? TEST_SITE_KEY : PUBLIC_TURNSTILE_SITE_KEY;
---

<form
	method="POST"
	action={actions.submitContact}
	class="mx-auto flex max-w-md flex-col gap-4"
>
	<label class="flex flex-col gap-1 text-sm">
		Name
		<input
			type="text"
			name="name"
			autocomplete="name"
			required
			maxlength="200"
			class="rounded border border-black/20 px-3 py-2"
		/>
	</label>
	<label class="flex flex-col gap-1 text-sm">
		Email
		<input
			type="email"
			name="email"
			autocomplete="email"
			required
			maxlength="200"
			class="rounded border border-black/20 px-3 py-2"
		/>
	</label>
	<label class="flex flex-col gap-1 text-sm">
		Message
		<textarea
			name="message"
			required
			minlength="10"
			maxlength="5000"
			rows="5"
			class="rounded border border-black/20 px-3 py-2"></textarea>
	</label>
	{siteKey && <div class="cf-turnstile" data-sitekey={siteKey} />}
	<button
		type="submit"
		class="rounded bg-black px-4 py-2 text-white hover:bg-black/80"
	>
		Send
	</button>
	{
		result?.data?.ok && (
			<p class="text-sm text-green-700">Thanks — we'll be in touch.</p>
		)
	}
	{result?.error && <p class="text-sm text-red-700">{result.error.message}</p>}
</form>

{
	siteKey && (
		<script
			is:inline
			set:html={`(() => {
  // Lazy-load Turnstile on first form interaction. Loading eagerly causes a
  // "preload not used" console warning because api.js preloads its challenge
  // script and the browser expects it to be consumed within a few seconds of
  // the page load event.
  let loaded = false;
  const load = () => {
    if (loaded) return;
    loaded = true;
    const s = document.createElement('script');
    s.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
    s.async = true;
    s.defer = true;
    document.head.appendChild(s);
  };
  const form = document.querySelector('form');
  if (!form) return;
  form.addEventListener('focusin', load, { once: true });
  form.addEventListener('pointerdown', load, { once: true });
})();`}
		/>
	)
}
